<CreateAccountWindow>:
    name: "create"
    namee: namee
    email: email
    password: passw

    FloatLayout:
        Label:
            text: "Crie sua Conta"
            size_hint: 0.8, 0.2
            pos_hint: {"x": 0.1, "top": 1}
            font_size: (root.width**2 + root.height**2) / 14**4

        Label:
            text: "Nome: "
            size_hint: 0.5, 0.12
            pos_hint: {"x": 0, "top": 0.8}
            font_size: (root.width**2 + root.height**2) / 14**4

        TextInput:
            id: namee
            size_hint: 0.4, 0.12
            pos_hint: {"x": 0.5, "top": 0.8}
            multiline: False

        Label:
            text: "Email: "
            size_hint: 0.5, 0.12
            pos_hint: {"x": 0, "top": 0.8 - 0.13}
            font_size: (root.width**2 + root.height**2) / 14**4

        TextInput:
            id: email
            size_hint: 0.4, 0.12
            pos_hint: {"x": 0.5, "top": 0.8 - 0.13}
            multiline: False

        Label:
            text: "Senha: "
            size_hint: 0.5, 0.12
            pos_hint: {"x": 0, "top": 0.8 - 0.13*2}
            font_size: (root.width**2 + root.height**2) / 14**4

        TextInput:
            id: passw
            size_hint: 0.4, 0.12
            pos_hint: {"x": 0.5, "top": 0.8 - 0.13*2}
            multiline: False
            password: True

        Button:
            text: "Já possui conta? Faça Login"
            size_hint: 0.4, 0.1
            pos_hint: {"x": 0.3, "y": 0.25}
            font_size: (root.width**2 + root.height**2) / 17**4
            on_release:
                root.manager.transition.direction = "left"
                root.login()

        Button:
            text: "Registrar"
            size_hint: 0.6, 0.15
            pos_hint: {"x": 0.2, "y": 0.05}
            font_size: (root.width**2 + root.height**2) / 14**4
            on_release:
                root.manager.transition.direction = "left"
                root.submit()

<LoginWindow>:
    name: "login"
    email: email
    password: password

    FloatLayout:
        Label:
            text: "Email: "
            size_hint: 0.35, 0.15
            pos_hint: {"x": 0.1, "top": 0.9}
            font_size: (root.width**2 + root.height**2) / 13**4

        TextInput:
            id: email
            size_hint: 0.4, 0.15
            pos_hint: {"x": 0.45, "top": 0.9}
            multiline: False

        Label:
            text: "Senha: "
            size_hint: 0.35, 0.15
            pos_hint: {"x": 0.1, "top": 0.7}
            font_size: (root.width**2 + root.height**2) / 13**4

        TextInput:
            id: password
            size_hint: 0.4, 0.15
            pos_hint: {"x": 0.45, "top": 0.7}
            multiline: False
            password: True

        Button:
            text: "Login"
            size_hint: 0.6, 0.2
            pos_hint: {"x": 0.2, "y": 0.05}
            font_size: (root.width**2 + root.height**2) / 13**4
            on_release:
                root.manager.transition.direction = "up"
                root.loginBtn()

        Button:
            text: "Não tem uma conta? Bora criar!"
            size_hint: 0.4, 0.1
            pos_hint: {"x": 0.3, "y": 0.3}
            font_size: (root.width**2 + root.height**2) / 17**4
            on_release:
                root.manager.transition.direction = "right"
                root.createBtn()

<MainWindow>:
    name: "main"
    n: n
    email: email
    created: created

    FloatLayout:
        Label:
            id: n
            text: "Nome da Conta: "
            size_hint: 0.8, 0.2
            pos_hint: {"x": 0.1, "top": 0.9}

        Label:
            id: email
            text: "Email: "
            size_hint: 0.8, 0.2
            pos_hint: {"x": 0.1, "top": 0.7}

        Label:
            id: created
            text: "Criado em: "
            size_hint: 0.8, 0.2
            pos_hint: {"x": 0.1, "top": 0.5}

        Button:
            text: "Sair / LogOut"
            size_hint: 0.6, 0.2
            pos_hint: {"x": 0.2, "y": 0.1}
            on_release:
                app.root.current = "login"
                root.manager.transition.direction = "down"